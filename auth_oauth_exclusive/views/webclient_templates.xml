<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Hide password form fields, show only OAuth login buttons -->
    <template id="auth_oauth_exclusive_login" inherit_id="web.login" name="OAuth Exclusive Login">
        <xpath expr="//form[hasclass('oe_login_form')]" position="inside">
            <style>
                /* Hide password login form elements, keep OAuth buttons */
                .oe_login_form .mb-3,
                .oe_login_form .clearfix.oe_login_buttons .btn-primary[type="submit"],
                .oe_login_form a[href*="signup"],
                .oe_login_form a[href*="reset_password"],
                .oe_login_form input[name="csrf_token"],
                .oe_login_form input[name="redirect"] {
                    display: none !important;
                }
                /* "- or -" separator not needed when only OAuth */
                .oe_login_form em.text-muted {
                    display: none !important;
                }
                /* Hide "Log in as superuser" debug button */
                .oe_login_form button[name="redirect"][value="/web/become"] {
                    display: none !important;
                }
                /* Hide all submit buttons in the login form */
                .oe_login_form .oe_login_buttons {
                    display: none !important;
                }
            </style>
        </xpath>
    </template>
</odoo>
